{
  "name": "define-query",
  "version": "0.2.0",
  "description": "Define TanStack Query options once — queries, mutations, optimistic updates, and row state.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "react",
    "tanstack-query",
    "react-query",
    "query",
