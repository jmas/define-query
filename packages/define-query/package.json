    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@types/react": "^19.2.14",
    "react": "^19.2.6",
    "tsup": "^8.5.0",
    "typescript": "~6.0.2",
    "vitest": "^3.2.4"
  }
