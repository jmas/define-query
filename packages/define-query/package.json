      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "README.uk.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
